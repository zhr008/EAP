<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>OpcDaNetCore</id>
    <version>2.0.0</version>
    <title>Opc Da for .Net</title>
    <authors>Artur Dias</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/ArturDias98/OpcDaNetCore</projectUrl>
    <description>OPC DA implementation for .Net applications</description>
    <tags>opc opcda dotnet</tags>
    <repository url="https://github.com/ArturDias98/OpcDaNetCore" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.1">
        <dependency id="Quick.OpcNetApi" version="2.1.108" exclude="Build,Analyzers" />
        <dependency id="Quick.OpcNetApi.Com" version="2.1.108" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Quick.OpcNetApi" version="2.1.108" exclude="Build,Analyzers" />
        <dependency id="Quick.OpcNetApi.Com" version="2.1.108" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>