<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>NModbus.Transport.Serial</id>
    <version>4.0.0-alpha010</version>
    <authors>Rich Quackenbush</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <description>Serial (RTU/ASCII) Transport for NModbus.</description>
    <repository type="git" commit="2d255cb2bfe8b65ed04801840b6fb6bcb189d3b0" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="NModbus" version="4.0.0-alpha010" exclude="Build,Analyzers" />
        <dependency id="System.IO.Ports" version="7.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="NModbus" version="4.0.0-alpha010" exclude="Build,Analyzers" />
        <dependency id="System.IO.Ports" version="7.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="NModbus" version="4.0.0-alpha010" exclude="Build,Analyzers" />
        <dependency id="System.IO.Ports" version="7.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>