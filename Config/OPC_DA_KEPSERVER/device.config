<?xml version="1.0" encoding="utf-8"?>
<DeviceConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <DeviceId>OPC_DA_KEPSERVER</DeviceId>
  <DeviceName>KepServerEX OPC DA</DeviceName>
  <Enabled>false</Enabled>
  <ProtocolType>OpcDa</ProtocolType>
  <ConnectionTimeout>3000</ConnectionTimeout>
  <UpdateRate>100</UpdateRate>
  <HeartbeatInterval>3000</HeartbeatInterval>
  <HeartbeatTimeout>5000</HeartbeatTimeout>
  <HeartbeatFailuresBeforeDisconnect>3</HeartbeatFailuresBeforeDisconnect>
  <Description>KepServerEX OPC DA 服务器配置</Description>
  <OpcDaConfig>
    <ServerProgId>Kepware.KEPServerEX.V6</ServerProgId>
    <DeadBand>0.0</DeadBand>
    <UseAnonymousAuth>true</UseAnonymousAuth>
  </OpcDaConfig>
  <Tags>
    <Tag Id="TAG_OPC_DA_001" Name="设备状态">
      <NodeId>Channel1.Device1.Status</NodeId>
      <DataType>Int32</DataType>
      <ReadOnly>true</ReadOnly>
      <IsHeartbeatTag>true</IsHeartbeatTag>
      <Description>设备运行状态（用于心跳检测）</Description>
    </Tag>
    <Tag Id="TAG_OPC_DA_002" Name="流量传感器">
      <NodeId>Channel1.Device1.FlowRate</NodeId>
      <DataType>Float</DataType>
      <ReadOnly>false</ReadOnly>
      <Description>流量传感器值</Description>
    </Tag>
    <Tag Id="TAG_OPC_DA_003" Name="液位">
      <NodeId>Channel1.Device1.Level</NodeId>
      <DataType>Float</DataType>
      <ReadOnly>false</ReadOnly>
      <Description>液位值</Description>
    </Tag>
  </Tags>
</DeviceConfig>