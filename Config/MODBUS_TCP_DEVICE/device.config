<?xml version="1.0" encoding="utf-8"?>
<DeviceConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <DeviceId>MODBUS_TCP_DEVICE</DeviceId>
  <DeviceName>Modbus TCP 设备</DeviceName>
  <Enabled>true</Enabled>
  <ProtocolType>Modbus</ProtocolType>
  <ConnectionTimeout>3000</ConnectionTimeout>
  <UpdateRate>100</UpdateRate>
  <Description>Modbus TCP 协议设备示例</Description>
  <ModbusConfig>
    <Host>127.0.0.1</Host>
    <Port>502</Port>
    <Mode>Tcp</Mode>
    <SlaveId>1</SlaveId>
    <ConnectionTimeout>5000</ConnectionTimeout>
    <SerialPort>COM1</SerialPort>
    <BaudRate>9600</BaudRate>
    <DataBits>8</DataBits>
    <Parity>None</Parity>
    <StopBits>1</StopBits>
    <ReadTimeout>100</ReadTimeout>
    <WriteTimeout>100</WriteTimeout>
  </ModbusConfig>
  <Tags>
    <Tag>
      <Id>Coil_00001</Id>
      <Name>线圈 1</Name>
      <Address>00001</Address>
      <NodeId>FC01:0</NodeId>
      <DataType>Boolean</DataType>
      <ReadOnly>false</ReadOnly>
      <Description>数字输出线圈</Description>
      <ScanRate>1000</ScanRate>
    </Tag>
    <Tag>
      <Id>Input_00001</Id>
      <Name>输入 1</Name>
      <Address>20001</Address>
      <NodeId>FC02:0</NodeId>
      <DataType>Boolean</DataType>
      <ReadOnly>true</ReadOnly>
      <Description>数字输入</Description>
      <ScanRate>1000</ScanRate>
    </Tag>
    <Tag>
      <Id>Register_40001</Id>
      <Name>保持寄存器 1</Name>
      <Address>40001</Address>
      <NodeId>FC03:40001</NodeId>
      <DataType>Int32</DataType>
      <ReadOnly>false</ReadOnly>
      <Description>保持寄存器</Description>
      <ScanRate>500</ScanRate>
    </Tag>
    <Tag>
      <Id>InputReg_30001</Id>
      <Name>输入寄存器 1</Name>
      <Address>30001</Address>
      <NodeId>FC04:30001</NodeId>
      <DataType>Int32</DataType>
      <ReadOnly>true</ReadOnly>
      <Description>输入寄存器</Description>
      <ScanRate>1000</ScanRate>
    </Tag>
  </Tags>
</DeviceConfig>