<?xml version="1.0" encoding="utf-8"?>
<DeviceConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Id>OPC_UA_KEPSERVER</Id>
  <Name>KepServerEX OPC UA</Name>
  <Enabled>false</Enabled>
  <ProtocolType>OpcUa</ProtocolType>
  <ConnectionTimeout>3000</ConnectionTimeout>
  <UpdateRate>100</UpdateRate>
  <Description>KepServerEX OPC UA 服务器配置</Description>
  <OpcUaConfig>
    <EndpointUrl>opc.tcp://localhost:49320</EndpointUrl>
    <SessionTimeout>60000</SessionTimeout>
    <EnableAutoReconnect>true</EnableAutoReconnect>
    <ReconnectInterval>3000</ReconnectInterval>
    <SkipCertificateValidation>true</SkipCertificateValidation>
    <UseAnonymousAuth>true</UseAnonymousAuth>
  </OpcUaConfig>
  <Tags>
    <Tag Id="TAG_OPC_UA_001" Name="温度传感器">
      <NodeId>ns=2;s=Channel1.Device1.Temperature</NodeId>
      <DataType>Float</DataType>
      <ReadOnly>false</ReadOnly>
      <Description>温度传感器值</Description>
      <MinValue>-100</MinValue>
      <MaxValue>200</MaxValue>
    </Tag>
    <Tag Id="TAG_OPC_UA_002" Name="压力传感器">
      <NodeId>ns=2;s=Channel1.Device1.Pressure</NodeId>
      <DataType>Float</DataType>
      <ReadOnly>false</ReadOnly>
      <Description>压力传感器值</Description>
    </Tag>
    <Tag Id="TAG_OPC_UA_003" Name="设备状态">
      <NodeId>ns=2;s=Channel1.Device1.Status</NodeId>
      <DataType>Int32</DataType>
      <ReadOnly>true</ReadOnly>
      <Description>设备运行状态</Description>
    </Tag>
  </Tags>
</DeviceConfig>