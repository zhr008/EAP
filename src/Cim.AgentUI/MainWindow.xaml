<Window x:Class="Cim.AgentUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CIM Agent - Device Monitor" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 设备状态面板 -->
        <GroupBox Grid.Row="0" Header="Device Status" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Device ID:" FontWeight="Bold"/>
                    <TextBox x:Name="TxtDeviceId" Text="DEVICE-001" IsReadOnly="True"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Connection State:" FontWeight="Bold"/>
                    <TextBox x:Name="TxtConnectionState" Text="Disconnected" IsReadOnly="True" 
                             Background="#FFE0E0" FontWeight="Bold"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Equipment State:" FontWeight="Bold"/>
                    <TextBox x:Name="TxtEquipmentState" Text="OFFLINE" IsReadOnly="True" 
                             Background="#FFE0E0" FontWeight="Bold"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="Last Update:" FontWeight="Bold"/>
                    <TextBox x:Name="TxtLastUpdate" Text="-" IsReadOnly="True"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 控制按钮 -->
        <GroupBox Grid.Row="1" Header="Control Panel" Margin="0,0,0,10">
            <WrapPanel>
                <Button x:Name="BtnConnect" Content="Connect" Click="BtnConnect_Click" Width="100"/>
                <Button x:Name="BtnDisconnect" Content="Disconnect" Click="BtnDisconnect_Click" Width="100" IsEnabled="False"/>
                <Button x:Name="BtnGetStatus" Content="Get Status (S1F13)" Click="BtnGetStatus_Click" Width="120" IsEnabled="False"/>
                <Button x:Name="BtnCollectData" Content="Collect Data (S2F13)" Click="BtnCollectData_Click" Width="120" IsEnabled="False"/>
                <Button x:Name="BtnUploadRecipe" Content="Upload Recipe (S7F1)" Click="BtnUploadRecipe_Click" Width="120" IsEnabled="False"/>
                <Button x:Name="BtnDownloadRecipe" Content="Download Recipe (S7F5)" Click="BtnDownloadRecipe_Click" Width="120" IsEnabled="False"/>
                <Button x:Name="BtnClearLog" Content="Clear Log" Click="BtnClearLog_Click" Width="100"/>
            </WrapPanel>
        </GroupBox>

        <!-- 日志显示区域 -->
        <GroupBox Grid.Row="2" Header="Communication Log" Margin="0,0,0,10">
            <TextBox x:Name="TxtLog" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12"
                     TextWrapping="NoWrap" AcceptsReturn="True"/>
        </GroupBox>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusMessage" Text="Ready"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtMessageCount" Text="Messages: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
